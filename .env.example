# Server
PORT=8080
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=radio_db

# Streaming
STREAM_BUFFER_SIZE=65536
STREAM_READ_TIMEOUT=30s
STREAM_WRITE_TIMEOUT=30s
STREAM_RETRY_ATTEMPTS=3
STREAM_RETRY_DELAY=2s

# HTTP Client
MAX_IDLE_CONNS=100
MAX_IDLE_CONNS_PER_HOST=50
IDLE_CONN_TIMEOUT=90s

# Sync
SYNC_INTERVAL=6h
